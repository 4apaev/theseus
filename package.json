{
    "name"       : "theseus",
    "version"    : "0.0.0",
    "description": "interstellar trade game",
    "repository" : "github:4apaev/theseus",
    "type"       : "module",

    "workspaces" : [
        "apps/*",
        "packages/*"
    ],

    "imports": {
        "#apps/*"       : "./apps/*",
        "#packages/*"   : "./packages/*",

        "#service/*"    : "./apps/*",
        "#app/*"        : "./apps/*",
        "#pkg/*"        : "./packages/*",

        "#gateway/*"    : "./apps/gateway-service/src/*",
        "#market/*"     : "./apps/market-service/src/*",
        "#projection/*" : "./apps/projection-service/src/*",
        "#player/*"     : "./apps/player-service/src/*",
        "#ship/*"       : "./apps/ship-service/src/*",

        "#db/*"         : "./packages/db/src/*",
        "#kafka/*"      : "./packages/kafka/src/*",
        "#contracts/*"  : "./packages/contracts/src/*",
        "#domain/*"     : "./packages/domain/src/*",
        "#config/*"     : "./packages/config/src/*",
        "#util/*"       : "./packages/util/src/*",
        "#testing/*"    : "./packages/testing/src/*"
    },
    "scripts": {
        "prepare"       : "git config core.hooksPath scripts/hooks",
        "env:update"    : "bash scripts/hooks/pre-push",
        "test"          : "bash scripts/test.sh",
        "lint"          : "eslint .",
        "tsc"           : "tsc --noEmit",
        "check"         : "npm run test && npm run lint && npm run tsc",
        "infra:up"      : "docker compose -f infra/docker-compose.yml up -d",
        "infra:down"    : "docker compose -f infra/docker-compose.yml down",
        "infra:logs"    : "docker compose -f infra/docker-compose.yml logs -f",
        "infra:ps"      : "docker compose -f infra/docker-compose.yml ps",
        "infra:health"  : "node scripts/infra-health.js",
        "services:check": "node scripts/services-check.js",
        "smoke"         : "node --env-file=./.env --env-file=./.env.dev scripts/smoke.js"
    },
    "dependencies": {
        "garage": "github:4apaev/garage"
    },
    "devDependencies": {
        "typescript" : "^7.0.2",
        "globals"    : "^17.7.0",
        "eslint"     : "^10.7.0",
        "@eslint/js" : "^10.0.1",
        "@types/node": "^26.1.1"
    }
}