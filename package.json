{
    "name"       : "theseus",
    "version"    : "0.0.0",
    "description": "interstellar trade game",
    "repository" : "github:4apaev/theseus",
    "type"       : "module",
    "private"    : true,

    "workspaces" : [
        "apps/*",
        "packages/*"
    ],

    "imports": {
        "#apps/*"    : "./apps/*",
        "#packages/*": "./packages/*"
    },
    "scripts": {
        "prepare"       : "git config core.hooksPath .githooks",
        "env:update"    : "bash .githooks/pre-push",
        "test"          : ". ./scripts/test.sh",
        "lint"          : "eslint .",
        "tsc"           : "tsc --noEmit",
        "check"         : "npm run test && npm run lint && npm run tsc",
        "infra:up"      : "docker compose -f infra/docker-compose.yml up -d",
        "infra:down"    : "docker compose -f infra/docker-compose.yml down",
        "infra:logs"    : "docker compose -f infra/docker-compose.yml logs -f",
        "infra:ps"      : "docker compose -f infra/docker-compose.yml ps",
        "infra:health"  : "node scripts/infra-health.js",
        "services:check": "node scripts/services-check.js"
    },
    "dependencies": {
        "garage": "github:4apaev/garage"
    },
    "devDependencies": {
        "@eslint/js" : "^10.0.1",
        "@types/node": "^25.9.3",
        "eslint"     : "^10.5.0",
        "globals"    : "^17.6.0",
        "typescript" : "^6.0.3"
    }
}