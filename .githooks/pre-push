#!/usr/bin/env bash
set -euo pipefail

# if .env doesn't exist yet (fresh clone), the script will create an empty .env.example and exit 0
[ -f .env ] || { echo "pre-push: .env not found"; exit 1; }

sed \
    -e 's/#.*//g'         \
    -e 's/=.*/=🦄/g'      \
    -e '/^[[:space:]]*$/d' \
    .env > .env.example

git add .env.example

if ! git diff --cached --quiet HEAD -- .env.example; then
    echo ""
    echo "  .env.example was updated — commit it first:"
    echo "  git commit -m 'update .env.example'"
    echo ""
    exit 1
fi
