# test-suited overrides, stacked on top of .env by scripts/test.sh
# and npm run smoke (later --env-file wins; real env beats both)

# shrink travel: sol.outpost → barnards.port = 6.0 ly / 0.6c ≈ 1s
TIME_SCALE=0.1

# outbox rows publish almost immediately - specs wait on outbox-relayed
# events constantly, the 1s production default dominates integration time
OUTBOX_INTERVAL=25
