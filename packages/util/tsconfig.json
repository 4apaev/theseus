{
  "compilerOptions": {
    "types"                            : [ "./types" ],
    "rootDir"                          : "../../",
    "outDir"                           : "dist",
    "target"                           : "es2025",
    "module"                           : "NodeNext",
    "moduleResolution"                 : "NodeNext",
    "forceConsistentCasingInFileNames" : true,
    "esModuleInterop"                  : true,
    "declaration"                      : true,
    "allowJs"                          : true,
    "pretty"                           : true,
    "strict"                           : false
  },
  "include": [ "src" ],
}
